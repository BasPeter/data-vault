{
  "name": "data-vault",
  "version": "0.1.0",
  "private": true,
  "description": "A desktop viewer for Git-backed HTML knowledge vaults.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "postinstall": "install-electron --no",
    "dev": "electron-vite dev",
    "build": "tsc -b && electron-vite build",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "dompurify": "^3.2.6",
    "lucide-react": "^0.469.0",
    "mermaid": "^11.4.1",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.2.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "dev.poweredbybp.data-vault",
    "productName": "Data Vault",
    "asar": true,
    "files": ["out/**/*", "package.json"],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": ["AppImage", "deb"] }
  }
}
