{
  "name": "data-vault",
  "version": "0.12.4",
  "private": true,
  "description": "A desktop viewer for Git-backed HTML knowledge vaults.",
  "repository": "https://github.com/BasPeter/data-vault.git",
  "author": {
    "name": "BasPeter",
    "email": "23128615+BasPeter@users.noreply.github.com"
  },
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "postinstall": "install-electron --no && node scripts/install-git-hooks.mjs",
    "prebuild": "node scripts/generate-changelog.mjs",
    "icon": "electron scripts/render-icon.mjs",
    "dev": "electron-vite dev",
    "build": "tsc -b && electron-vite build",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "dompurify": "^3.2.6",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.469.0",
    "marked": "^16.4.2",
    "mermaid": "^11.4.1",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.2.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.7",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "dev.poweredbybp.data-vault",
    "productName": "Data Vault",
    "artifactName": "${name}-${version}-${arch}.${ext}",
    "asar": true,
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon.win.png",
        "to": "icon.win.png"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "BasPeter",
        "repo": "data-vault"
      }
    ],
    "electronUpdaterCompatibility": ">=2.16",
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "notarize": true
    },
    "win": {
      "icon": "build/icon.win.png",
      "target": "nsis"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
